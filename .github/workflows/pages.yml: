name: pages

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  deploy:
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - uses: actions/checkout@v4

      # optional: regen architecture-glass.svg (skip if SVG is committed)
      # - uses: actions/checkout@v4
      #   with:
      #     repository: vdutts7/visual-tokens
      #     path: skills/visual-tokens
      #     token: ${{ secrets.VT_PAT }}
      # - run: SKILLS=$GITHUB_WORKSPACE/skills bash scripts/render-architecture-glass.sh

      - uses: actions/upload-pages-artifact@v3
        with:
          path: docs

      - id: deployment
        uses: actions/deploy-pages@v4
