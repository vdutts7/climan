{
  "_about": "SOT for climan.dev. Bundled with /manpages skill.",
  "version": "2.0",
  "skill": "manpages",

  "worker": {
    "name": "manpages",
    "base_url": "https://climan.dev",
    "fallback_url": "https://manpages.manpages.workers.dev",
    "custom_domain": "climan.dev"
  },

  "kv": {
    "binding": "MAC",
    "entry_count": 15299,
    "sources": ["/usr/share/man", "/opt/homebrew/share/man"],
    "excluded": ["/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/share/man"],
    "exclusion_reason": "SDK dir is C stdlib, not macOS CLI commands"
  },

  "routes": {
    "root":      { "path": "/",                "returns": "service info + available namespaces" },
    "mac":       { "path": "/mac/{cmd}",       "returns": "macOS man page JSON, best section auto-selected" },
    "mac_exact": { "path": "/mac/{cmd}.{n}",   "returns": "macOS man page JSON for specific section" },
    "manifest":  { "path": "/mac",             "returns": "all 15299 commands with section info" },
    "search":    { "path": "/search?q=term",   "returns": "up to 50 matching commands from manifest" },
    "legacy":    { "path": "/man/{cmd}",       "returns": "backward compat, same as /mac/{cmd}" },
    "robots":    { "path": "/robots.txt",      "returns": "Allow: /" }
  },

  "namespaces": {
    "mac": { "status": "live", "entries": 15299, "kv_prefix": "cmd:" },
    "pwsh": { "status": "planned" },
    "brew": { "status": "planned" },
    "linux": { "status": "planned" },
    "npm": { "status": "planned" }
  },

  "section_priority": ["1", "8", "5", "7", "3", "2", "4", "6", "9", "n"],

  "safe_test_commands": ["ls", "curl", "networksetup", "defaults", "diskutil", "sw_vers", "caffeinate", "osascript", "launchctl", "date", "whoami", "uptime"],

  "operator_refresh": {
    "repo": "https://github.com/vdutts7/climan",
    "extract": "./scripts/extract.sh",
    "upload": "./scripts/upload.sh",
    "deploy": "./scripts/deploy.sh",
    "test": "./test.sh"
  }
}
